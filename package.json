{
  "name": "froggy-rag-mcp",
  "version": "1.0.18",
  "description": "Turnkey RAG system with MCP server and UI",
  "main": "src/main/main.js",
  "bin": {
    "froggy-rag-mcp": "./src/cli/mcp-cli.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 electron . --dev",
    "test": "node --test",
    "clean:dist": "node scripts/clean-dist.js",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:all": "electron-builder",
    "build:publish": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish always",
    "postbuild:publish": "node scripts/assert-dist-win-exe.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "release": "npm run version:patch && npm run build:publish",
    "postinstall": "node scripts/electron-rebuild-native.cjs",
    "mcp-stdio": "node src/cli/mcp-cli.js",
    "mcp": "node src/cli/mcp-cli.js"
  },
  "keywords": [
    "rag",
    "mcp",
    "electron",
    "vector-store"
  ],
  "author": "Froggy on RAG",
  "license": "MIT",
  "overrides": {
    "node-abi": "^4.28.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.1",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.5.3",
    "docx": "^8.2.2",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "html-to-text": "^9.0.5",
    "mammoth": "^1.6.0",
    "marked": "^17.0.0",
    "natural": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.froggy.ragmcp",
    "productName": "Froggy on RAG",
    "icon": "images/Froggy RAG.png",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "images/Froggy RAG - Splash.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "deepblue523",
      "repo": "froggy-mcp-rag"
    },
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "sign": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "msi": {
      "oneClick": false,
      "menuCategory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "warningsAsErrors": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "warningsAsErrors": false
    }
  }
}
